# VectorFlow Environment Configuration
# Copy this file to .env and fill in your values

# OpenAI API Key (Required for embeddings and LLM)
OPENAI_API_KEY=sk-your-openai-api-key-here

# PostgreSQL Configuration
POSTGRES_DB=vectorflow
POSTGRES_USER=vectorflow
POSTGRES_PASSWORD=vectorflow123

# JWT Secret (Change in production!)
JWT_SECRET=vectorflow-super-secret-key-change-in-production

# CORS Allowed Origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Optional: Redis password (if needed)
# REDIS_PASSWORD=

